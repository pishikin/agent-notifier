{
    "name": "agent-notifier",
    "version": "1.0.0",
    "description": "macOS hook-first notifier for Claude and Codex turn completions inside Cursor",
    "type": "module",
    "bin": {
        "agent-notifier": "./dist/index.js"
    },
    "engines": {
        "node": ">=22",
        "os": ["darwin"]
    },
    "files": [
        "dist",
        "scripts"
    ],
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "commander": "^13.0.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}
